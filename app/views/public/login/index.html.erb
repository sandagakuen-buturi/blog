<main class="w-full min-h-[80%] flex items-center justify-center">
  <div class="w-full max-w-md mx-4 bg-white border border-gray-200 rounded-lg p-8">
    <header class="text-center mb-6">
      <div class="flex items-center justify-center gap-3">
        <div class="w-10 h-10 bg-blue-600 rounded flex items-center justify-center text-white font-bold">B</div>
        <div>
          <h1 class="text-2xl font-semibold text-gray-800">ログイン</h1>
          <p class="text-sm text-gray-500">あなたのアカウントにサインインしてください</p>
        </div>
      </div>
    </header>

    <div>
      <% if flash[:alert].present? %>
        <div role="alert" class="mb-4 text-sm text-red-700 border border-red-100 rounded p-3 bg-red-50">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: "/api/login", method: :post, local: true, html: { autocomplete: 'on' } do |form| %>
        <div class="mb-4">
          <%= form.label :email, "メールアドレス", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.email_field :email, required: true, autofocus: true, placeholder: "you@example.com", aria: { describedby: 'email-help' }, autocomplete: 'email', class: "w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-blue-600" %>
          <p id="email-help" class="mt-1 text-xs text-gray-500">登録済みのメールアドレスを入力してください。</p>
        </div>

        <div class="mb-4">
          <div class="flex items-center justify-between">
            <%= form.label :password, "パスワード", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= link_to "パスワードを忘れた", "/forgot_password", class: "text-sm text-blue-600 hover:underline" %>
          </div>
          <%= form.password_field :password, required: true, placeholder: "パスワード", autocomplete: 'current-password', aria: { describedby: 'pw-help' }, class: "w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-blue-600" %>
          <p id="pw-help" class="mt-1 text-xs text-gray-500">8文字以上のパスワードを入力してください。</p>
        </div>

        <div class="mb-6 flex items-center">
          <label for="remember_me" class="inline-flex items-center text-sm text-gray-600">
            <%= form.check_box :remember_me, { id: 'remember_me', class: "mr-2" }, "1", "0" %>
            ログイン状態を保持する
          </label>
        </div>

        <div class="mb-4">
          <%= form.submit "ログイン", class: "w-full py-2 px-4 bg-blue-600 text-white rounded-md text-sm font-medium hover:opacity-95" %>
        </div>
      <% end %>
    </div>
  </div>
</main>
